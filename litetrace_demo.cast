[114.864262, "o", "\u001b[0;36mе·Іеұ•зӨәзҡ„жүҖжңүеҠҹиғҪпјҡ\u001b[0m\r\n\r\n\u001b[0;32mеҹәзЎҖе‘Ҫд»Өпјҡ\u001b[0m\r\n  вң“ tldr    - еҝ«йҖҹеё®еҠ©\r\n  вң“ status  - жҹҘзңӢ ftrace зҠ¶жҖҒ\r\n  вң“ search  - жҗңзҙўеҶ…ж ёеҮҪж•°пјҲж”ҜжҢҒжӯЈеҲҷпјү\r\n\r\n"]
[114.864401, "o", "\u001b[0;32mиҝҪиёӘжЁЎејҸпјҡ\u001b[0m\r\n  вң“ run       - еүҚеҸ°иҝҪиёӘпјҲйҳ»еЎһз»Ҳз«Ҝпјү\r\n  вң“ background- еҗҺеҸ°иҝҪиёӘпјҲдёҚйҳ»еЎһпјү\r\n  вң“ terminate - еҒңжӯўеҗҺеҸ°иҝҪиёӘ\r\n\r\n\u001b[0;32mй«ҳзә§еҠҹиғҪпјҡ\u001b[0m\r\n  вң“ --debug   - и°ғиҜ•жЁЎејҸпјҲжҳҫзӨә tracefs ж“ҚдҪңпјү\r\n"]
[114.864462, "o", "  вң“ tui       - е®һж—¶еӣҫеҪўз•Ңйқў\r\n  вң“ wizard    - дәӨдә’ејҸеҗ‘еҜј\r\n\r\n\u001b[0;32mиҝҪиёӘеҷЁзұ»еһӢпјҡ\u001b[0m\r\n"]
[114.864623, "o", "  вҖў function       - иҝҪиёӘеҮҪж•°е…ҘеҸЈпјҲиҪ»йҮҸпјү\r\n  вҖў function_graph - иҝҪиёӘи°ғз”Ёй“ҫпјҲиҜҰз»Ҷпјү\r\n  вҖў nop            - зҰҒз”ЁиҝҪиёӘ\r\n\r\n\u001b[1;33mжӣҙеӨҡдҝЎжҒҜиҜ·жҹҘзңӢпјҡ\u001b[0m\r\n  вҖў README.md          - йЎ№зӣ®иҜҙжҳҺ\r\n  вҖў docs/cheatsheet.txt - дҪҝз”ЁжүӢеҶҢ\r\n  вҖў docs/DEVELOPER.md   - ејҖеҸ‘иҖ…ж–ҮжЎЈ\r\n\r\n"]
